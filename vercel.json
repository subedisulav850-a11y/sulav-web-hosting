{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ],
  "env": {
    "SECRET_KEY": "your-secret-key-here-change-in-production",
    "ADMIN_PASSWORD": "Admin@123",
    "DEFAULT_USER_PASSWORD": "User@123"
  }
}